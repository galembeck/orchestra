{
	"extends": "@repo/typescript-config/base.json",
	"compilerOptions": {
		"baseUrl": ".",
		"paths": {
			"@core/*": [
				"src/*"
			]
		},
		"jsx": "react-jsx",
		"noEmit": true,
		"lib": [
			"ESNext",
			"DOM",
			"DOM.Iterable"
		]
	},
	"include": [
		"src"
	],
	"exclude": [
		"dist",
		"node_modules"
	]
}
